<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.0" snapToGrid="false">
  <code><![CDATA[

; GLOBAL VARIABLES -------------------------------------------------------------------
globals[
  season          ; breeding or non-breeding season
  year            ; year in the model run 
  total_birds     ; total number of living birds
  day             ; day of year
  total_eggs      ; total number of eggs laid in the season 
  chick_deaths    ; total number of chick deaths
  combined_egg_losses      ; combined egg losses 
  
  next_id_no
  
  ; fleding length 
  mean_fledge 
  sd_fledge 
  min_fledge 
  
  ; relay rates 
  clutch1_total
  clutch2_total
  clutch3_total 
  
  ; break down egg and chick losses 
  all_eggs
  infertile_eggs
  fertile_eggs
  failed_to_hatch
  abandoned_eggs 
  hatched 
  abandoned_chicks
  diseased_chicks
  fledged

  juvenile_deaths
  immature_deaths
  adult_deaths
  
  winter_adult_deaths
  winter_juvenile_deaths
  winter_immature_deaths
  
  juvenile_success
  immature_success
  
  ; storm specific globals 
  storm_no          ; for per season reporting 
  storm_active?     ; whether a storm is happening
  storm_severity    ; "small" / "large" / "extreme"
  storm_days_left   ; number of days remaining in the storm
  egg_abandonments
  failed_nests
  storm_egg_loss
  storm_chick_loss
  
  storm_adult_deaths 
  storm_immature_deaths
  storm_juvenile_deaths
  
  ; predation specific globals 
  avian_predator_active?    ; is a predator active? (by type)
  mam_predator_active?

  avian_species
  mam_species 
  
  avian_predator_days_left
  mam_predator_days_left
  
  ; tracking attacks of specific predator types 
  gull_pres
  shorebird_pres
  kahu_pres
  rat_pres
  other_mam_pres
  cat_pres 
  
  egg_loss_mammals
  egg_loss_avian
  chick_loss_mammals
  chick_loss_avian 
  
  
  
  
  ; annual trackers  
  annual_egg_loss_avian 
  annual_egg_loss_mammals 
  annual_total_eggs_laid 
  annual_chick_loss_avian 
  annual_chick_loss_mammals 
  annual_total_chicks_hatched
  
  annual_adult_start_year
  annual_adult_survival 
]


; TURTLE VARIABLES -------------------------------------------------------------------
turtles-own[
  
  id_no
  sex
  age_years       ; age of bird
  age_day         ; + day of year
  life_stage      ; chick, juvenile, immature, adult
  breeding?       ; will the bird make a breeding attempt?
  courting_time   ; time since courting began
  courting_length ; the time this pair will take to court
  pair_id         ; pair id of a courted bird
  nesting_patch   ; nest location

  condition          ; how well the bird is doing/the energy budget of the bird
  fertility_score    ; a combination of the parents condition and their genetic_code (diversity)


 ; incubating?        ; is the bird currently inclubating?
  incubation_time     ; time since incubation began
  incubation_length   ; number of days the clutch will need to be incubating 
  fledge_length       ; number of days the chick will need to fledge
  nest_reset          ; length of time since failed or completed clutch (required for relay attempt)
  nest_reset_length   ; the length of time a bird needs before relaying 
  
  clutch_state       ; "none" "incubating" "failed" "hatched" "finished"
  clutch_no          ; clutch number (of the breeding season)
  clutch_size        ; number of eggs in clutch
  fertile_eggs?      ; are the eggs fertile?
  chicks_alive       ; number of dependent chicks currently alive
  final_clutch?
  chick_status       ; to keep track of abandoned chicks 


  mother             ; maternal parent of the bird
  father             ; paternal parent of the bird
  siblings           ; in the same clutch
  previous_pair      ; pair_id from the last season  

]

; PATCH VARIABLES --------------------------------------------------------------------
patches-own[
habitat_suitability
]

; SET UP PROCEDURE -------------------------------------------------------------------
to setup
  ca

  ; globals---------------------------------------------------------------------------
   set season "non-breeding" 
   set day 122   ; starting in April 
   set year 0

   set infertile_eggs 0
   set failed_to_hatch 0
   set chick_deaths 0
   set fertile_eggs 0
   set combined_egg_losses 0

   set juvenile_deaths 0
   set immature_deaths 0
   set adult_deaths 0
   set total_eggs 0
   set abandoned_eggs 0
   set failed_to_hatch 0
   set hatched 0
   set abandoned_chicks 0
   set diseased_chicks 0
   set fledged 0

   set mean_fledge 31
   set sd_fledge 3
   set min_fledge 28 
   set clutch1_total 0
   set clutch2_total 0
   set clutch3_total 0 
  
   set winter_adult_deaths 0
   set winter_juvenile_deaths 0
   set winter_immature_deaths 0
  
   set next_id_no 1
  
   set juvenile_success 0
   set immature_success 0
  
  ; storm variables 
   set storm_active? false
   set storm_severity ""
   set storm_days_left 0
   set storm_no 0
   set storm_egg_loss 0
   set storm_chick_loss 0
  
   set storm_adult_deaths 0
   set storm_immature_deaths 0
   set storm_juvenile_deaths 0
  
  ; predation 
   set avian_predator_active? false 
   set mam_predator_active? false
   set avian_species "none"
   set mam_species "none"
   set avian_predator_days_left 0
   set mam_predator_days_left 0

   set gull_pres 0
   set shorebird_pres 0
   set kahu_pres 0
   set rat_pres 0
   set other_mam_pres 0
   set cat_pres 0 
  
   set egg_loss_mammals 0
   set egg_loss_avian 0
   set chick_loss_mammals 0
   set chick_loss_avian 0 
   
  
   set annual_egg_loss_avian 0
   set annual_egg_loss_mammals 0
   set annual_total_eggs_laid 0
  
   set annual_chick_loss_avian 0
   set annual_chick_loss_mammals 0
   set annual_total_chicks_hatched 0
   
   set annual_adult_survival 0
  

; create turtles -------------------------------------------------------------------
create-turtles initial_number [  ; controlled by a slider on the interface
  set size 6
  setxy random-xcor random-ycor
  move-to one-of patches
    
  set id_no next_id_no
  set next_id_no  next_id_no + 1  

  ; sex (60% male)
  set sex ifelse-value (random-float 1 < 0.6)
    ["male"] ["female"]

  ; life stage ---------------------------------------
    
  ; 80% adults, 10% juveniles, 10% immatures (for now)
let r random-float 1


ifelse r < 0.56 [
  ; adults (56%)
  set life_stage "adult"
 ; set age_years 2 + random 20
  set age_years floor random-triangular 2 5 21
  set age_day random  40 + random 80 ; during the breeding season 
  set color blue

] [
  ifelse r < 0.74 [
    ; immatures (18%)
    set life_stage "immature"
    set age_years 1
    set age_day random  40 + random 80
    set color red                  

  ] [
    ; juveniles (26%)
    set life_stage "juvenile"
    set age_years 0
    set age_day 40 + random 80 
    set color green
  ]
]

  ; breeding variables ------------------------------
  set breeding? false
  set incubation_time 0
  set courting_time 0
  set courting_length 0
  set clutch_no 0
  set mother nobody
  set father nobody
  set siblings nobody
  set nest_reset  0
  set clutch_state "none" 
  set chicks_alive 0
  set final_clutch? false
  set chick_status ""
  set previous_pair nobody 
  set nest_reset_length 0


  ; bird condition ----------------------------------

  set condition random-normal 0.8 0.2 
  set condition max list 0 min list condition 1 

  ; for now - look at fertility submodels plan 
  set fertility_score 0.75
]
  ; patch variables -----------------------------------------------------------
                                    
ask patches [
  set habitat_suitability random-float 1
]
  
  repeat 5 [
  ask patches [
    set habitat_suitability (habitat_suitability +
      mean [habitat_suitability] of neighbors) / 2
  ]
]
  
  let min-val min [habitat_suitability] of patches
  let max-val max [habitat_suitability] of patches

ask patches [
  set habitat_suitability (habitat_suitability - min-val) / (max-val - min-val)
]
  
  let target round (0.044 * count patches)

let threshold sort [habitat_suitability] of patches
set threshold item (length threshold - target) threshold

ask patches [
  if habitat_suitability >= threshold [
      set habitat_suitability one-of [0.8 0.9 1]
  ]
]
  
  ask patches [
  set pcolor scale-color yellow habitat_suitability 0 1
]
  
  set annual_adult_start_year count turtles with [life_stage = "adult"]

  reset-ticks
end

; GO PROCEDURE ----------------------------------------------------------------
to go
  
    if ticks >= 18300 [ ; stop after 50 years 
    stop]
  
  ; breeding procedures 
  court 
  
  clutch_manager ; clutch control (managing relays)
  
  hatch_eggs
  
  chick_phase 
  
  fledge_chicks
  
  ; threat procedures
  storm
  
  predation
  
  ; mortality procedures 
  energy_expenditure
    
  off_season ; winter condition + mortality calculations

  ; reset and display procedures 
  new_day
  
  update_outputs
  
  tick ; each tick represents 1 day

end

; courting procedure (breeding season only) ----------------------------------
to court 
    if season = "non-breeding" [stop] ; birds only court to prepare for breeding

  ask turtles [               

  ; continue courting --------------------------------------------------------
  if clutch_state = "paired" [                        ; if they are already courted their time courting will increase (move towards laying)
      set courting_time courting_time + 1     ; if they have had an unsuccessful clutch they will stay in the same pair for the season
  ]      ; create individual courting times to add some variation to the timing of laying

  ;  begin courting ----------------------------------------------------------
    if clutch_state = "none" and life_stage = "adult" and sex = "female"  and condition > courting_condition [
      
      ; select potential pair
      let candidate_males other turtles with [
      clutch_state = "none" and life_stage = "adult" and sex = "male" and condition > courting_condition ]
      
      let previous_male one-of candidate_males with [who = previous_pair]
      
      let potential_male nobody 
      
      if previous_male != nobody and random-float 1 < 0.5 [
        set potential_male previous_male
      ]
      
      if potential_male = nobody [set potential_male one-of candidate_males]
      
      ; make a courting attempt - not all birds to successfully pair 
      let courting_attempt? random-float 1 < court_success

      ; if previous_pair != nobody and it meets the potential_male criteria there is a 50% chance they will pair again
      ; pair them
      if potential_male != nobody and courting_attempt? [
      set breeding? true ; for output updates 
      set clutch_state "paired"
      set courting_time courting_time + 1
      set pair_id [who] of potential_male
      set previous_pair pair_id
      set courting_length random-normal 8 2
        
      ; set pair variables   
        ask potential_male [
          set breeding? true
          set clutch_state "paired"
          set courting_time courting_time + 1
          set pair_id [who] of myself
        ]
      ]
      if not courting_attempt? [
      set clutch_state "non-breeder"
        if potential_male != nobody [
    ask potential_male [
     ; set clutch_state "non-breeder"
        ]
      ]
    ]
  ]
  ]
end 

; incubation procedure ------------------------------------------------------------
to clutch_manager

  ; paired females will begin the incubation process 
  ask turtles with [
    sex = "female" and
    pair_id != nobody and
    clutch_state != "finished" and 
    life_stage = "adult"
  ] [

    ; clutch_state = none → attempt clutch
    ; ----------------------------------------
    if clutch_state = "paired" [
      if courting_time > courting_length [ ; if courting theshold met?
        attempt_new_clutch
      ]
      stop
    ]

    ; clutch_state = incubating
    ; ----------------------------------------
    if clutch_state = "incubating" [
      progress_incubation
      stop
    ]

    ; clutch_state = failed or fledged → relay decision
    ; ----------------------------------------
    if member? clutch_state ["failed" "fledged" "abandoned_chicks"][
      decide_relay
      stop
    ]
  ]
end


; incubation attempt --------------------------------------------------------------
to attempt_new_clutch

  if pair_id = nobody [ stop ] ; the bird must be courted 
  if clutch_no > 3 [ stop ]

  ; find a suitable nesting site ------------------------------
  let nest max-one-of patches with [
    habitat_suitability > patch_threshold
    and not any? turtles in-radius 2
  ][habitat_suitability]
  if nest = nobody [ stop ]     

  move-to nest
  set nesting_patch nest

  ; begin incubation ------------------------------------------
  set clutch_no clutch_no + 1
  set clutch_state "incubating" ; incubating
  set incubation_time 0

  ; set incubating variables ----------------------------------
  ; length
  set incubation_length (22 + random 4)
   
  ; clutch size

  
  ifelse random-float 1 < (mean_clutch_no - 1) [
  set clutch_size 2
] [
  set clutch_size 1
]
  
  set total_eggs total_eggs + clutch_size ; add to total tally 
  
 ifelse clutch_no = 1 [
  set clutch1_total clutch1_total + clutch_size
]
[
  ifelse clutch_no = 2 [
    set clutch2_total clutch2_total + clutch_size
  ]
  [
    if clutch_no = 3 [
      set clutch3_total clutch3_total + clutch_size
    ]
  ]
]

  ; fertility (female-driven for now) - this needs to change 
  set fertile_eggs? (random-float 1 < fertility_score)
  if fertile_eggs? [set fertile_eggs fertile_eggs + clutch_size]
  
  ; update partner 
    let partner turtle pair_id
    if partner != nobody [
      ask partner [
        set clutch_state "incubating"
        move-to [nesting_patch] of myself
        set clutch_no [clutch_no] of myself
        set incubation_time 0
        set clutch_size [clutch_size] of myself
        set incubation_length [incubation_length] of myself
        set fledge_length [fledge_length] of myself
      ]
    ]
  
end

; continue incubation until hatch ---------------------------------------------------
to progress_incubation
  
  ; incubating birds only 
  if clutch_state != "incubating" [ stop ] 
  
  let partner nobody 
  if pair_id != nobody [
   set partner turtle pair_id]
  ;let partner turtle pair_id

  ; partner death check -------------------------------------
  if partner = nobody [
    set clutch_state "finished" 
     set breeding? false
     set pair_id nobody
    set combined_egg_losses combined_egg_losses + clutch_size
    set abandoned_eggs abandoned_eggs + clutch_size ; management is able to save abandoned eggs  
    stop
  ]
  
  ; increase incubation time ---------------------------------
  set incubation_time incubation_time + 1
  
  ; update partner 
      ask partner [
        set incubation_time [incubation_time] of myself
      ]
  
  ; add in opportunity for infertile eggs to be spotted (candle eggs)
  if incubation_time = 10 [
    if random-float 1 < candle_success [ 
    if not fertile_eggs?[
      set clutch_state "failed" ; failed - simulate management removing infertile eggs     
      set nest_reset 0
      set nest_reset_length max list 0 round random-normal 19 9
      set infertile_eggs infertile_eggs + clutch_size        
      ask partner [
          set clutch_state "failed" ]
      ]
    ]
  ]
  
  
  ; identify fertile eggs -> hatch --------------------------
  if incubation_time >= incubation_length [
    if fertile_eggs? [
      set clutch_state "hatching" ; hatched
      ask partner [
          set clutch_state "hatching"
      ]
    ]
    
   ; remove remaining infertile eggs --------------------------------- 
    if not fertile_eggs? [
      set clutch_state "failed" ; failed
      set infertile_eggs infertile_eggs + clutch_size
      set nest_reset 0
      set nest_reset_length max list 0 round random-normal 19 9
      ask partner [
          set clutch_state "failed"
      ]
   ]
  ]
end

; determine if the pair will relay ----------------------------------------------
to decide_relay
  
  set nest_reset nest_reset + 1
  if nest_reset <= nest_reset_length [stop]
  
  let relay? false
  
  let partner turtle pair_id

  ; check the condition of the pair -------------------------
  if (clutch_no = 1 or clutch_no = 2) and partner != nobody and season = "breeding"[
  set relay? (condition > breeding_condition
              and [condition] of partner > breeding_condition) ; both birds must have the energetic capacity to relay
]
  
    ; for now a pair will not relay if chicks successfully fledge 
  if clutch_state = "fledged" [
    set relay? false]
  
  if final_clutch? [
    set relay? false ] ; maybe change this to say past a certain date they can't relay (look at the egg data)

  ; initiate relay attempt -----------------------------------
  if relay? [
    set clutch_state "none" ; none
    set courting_time 1
    set nest_reset 0
    
     ; update partner
    if partner != nobody [
      ask partner [
        set clutch_state "none" ; none
        set courting_time 1
      ]
    ]
  ]

  ; halt relay attempt ---------------------------------------
  if not relay? [
     ; update partner 
    if partner != nobody [
      ask partner [
        set clutch_state "finished"
        set breeding? false
        set pair_id nobody
      ]
    ]
    
    ; end breeding season for the pair 
    set clutch_state "finished" 
    set breeding? false
    set pair_id nobody
  ]
  
end


; successful incubations -> hatched eggs ---------------------------------------------
to hatch_eggs

  ; female birds that are incubating will hatch their successful eggs --
  ask turtles with [sex = "female" and clutch_state = "hatching"] [
    
    
    ; hatch failure (each egg is independent)
    let hatchlings 0
    
    repeat clutch_size [
      if random-float 1 > hatch_failure [
        set hatchlings hatchlings + 1
    ]
   ]
    
    let failed (clutch_size - hatchlings)                ; if failed is equal to clutch size the clutch fails 
    set failed_to_hatch failed_to_hatch + failed
    set combined_egg_losses combined_egg_losses + failed
    
    ; predetermine fledge length (so it can be passed on to the chick)
        set fledge_length max list min_fledge
        round random-normal mean_fledge sd_fledge  

    hatch hatchlings [       

      ; set chick variables ------------------------------------
      set life_stage "chick"
      set age_years 0
      set age_day 1
      set sex one-of ["male" "female"]


      set mother [who] of myself
      set father [pair_id] of myself

      ; set future adult variables -----------------------------
      set breeding? false
      set courting_time 0
      set courting_length 0
      set pair_id nobody
      set incubation_time ""
      set incubation_length ""
      set clutch_no 0
      set fertile_eggs? ""
      set final_clutch? false
      set clutch_size 0
      set clutch_state "none"
      set chicks_alive 0
      set nest_reset 0
      set fledge_length [fledge_length] of myself
      set chick_status "with_parents"
      set previous_pair nobody
      
      ; condition
      set condition random-normal 0.8 0.2 
      set condition max list 0 min list condition 1 

      ; genetics / fertility
      set fertility_score 0.75    ; change this so it is based on the genetics of the parents (tracking genetic diversity - inlcude an "infertile" gene)
      
      set hatched hatched + 1
    ]

    ; update perents on hatch success ---------------------------- 
    if hatchlings > 0 [
    ; update mother's status -------------------------------------
    set clutch_state "with_chicks"         
    set chicks_alive hatchlings
      

    ; update father's status -------------------------------------
    let partner turtle pair_id
    if partner != nobody [
      ask partner [
        set clutch_state "with_chicks"
        set chicks_alive hatchlings
      ]
    ]
  ]
  
    ; hatch failure ----------------------------------------------
    if hatchlings = 0 [ 
      set clutch_state "failed"
      let partner turtle pair_id
    if partner != nobody [
      ask partner [
        set clutch_state "failed"
        ]
      ]
    ] 
  ]
  
  
end

; raising chicks ------------------------------------------------------------------- 
to chick_phase 

  ; chicks will check that their parents are alive ---------------------------------
  ask turtles with [life_stage = "chick" ] [
    let mother-agent nobody
    let father-agent nobody

    if mother != nobody [
      set mother-agent turtle mother
    ]

    if father != nobody [
      set father-agent turtle father
    ]

     let mother_present? false
    let father_present? false

    if mother-agent != nobody [
      let m_state [clutch_state] of mother-agent
      if m_state = "with_chicks" or m_state = "with_chicks_solo" [
        set mother_present? true
      ]
    ]

    if father-agent != nobody [
      let f_state [clutch_state] of father-agent
      if f_state = "with_chicks" or f_state = "with_chicks_solo" [
        set father_present? true
      ]
    ]

    ; determine the chick status ---------------------------------------------------
    
    ; both parents caring
    if mother_present? and father_present? [
      set chick_status "with_parents"
    ]

    ; only one parent caring (other dead or abandoned)
    if (mother_present? != father_present?) [
      set chick_status "solo_parent"
      
      if mother_present? [
        ask mother-agent [
          set clutch_state "with_chicks_solo"
        ]
      ]
      
      if father_present? [
        ask father-agent [
          set clutch_state "with_chicks_solo"
        ]
      ]
    ]

    ; no parents caring → chick is abandoned and dies
    if (not mother_present?) and (not father_present?) [
      set abandoned_chicks abandoned_chicks + 1
      die
    ]
    
    ; health check ----------------------------------------------------------------
    if random-float 1 < chick_health [
      
      if mother-agent != nobody [
        ask mother-agent [
          set chicks_alive chicks_alive - 1
          if chicks_alive <= 0 [
            set clutch_state "finished"
              set breeding? false
              set pair_id nobody
        ]
      ]
    ]
      
      if father-agent != nobody [
        ask father-agent [
          set chicks_alive chicks_alive - 1
          if chicks_alive <= 0[
            set clutch_state "finished"
              set breeding? false
              set pair_id nobody
        ]
      ]
    ]
      
      set diseased_chicks diseased_chicks + 1
      die 
      
    ]
  ]

  
end 

; surviving chicks will fledge ---------------------------------------------------
to fledge_chicks  
  
  ask turtles with [life_stage = "chick"] [
    
  ; chicks will fledge when they are ready ---------------------------------------
  if age_day > fledge_length [

    set life_stage "juvenile"
    move-to one-of patches
    set color green
    set fledged fledged + 1
    set chick_status ""
    set fledge_length 0
   
    
    ; alert parents that their chick has fledged --------------------------------
    if mother != nobody [
      let mother-agent turtle mother
      if mother-agent != nobody [
        ask mother-agent [
          set chicks_alive chicks_alive - 1
          if chicks_alive <= 0 [
              set clutch_state "finished"
              set breeding? false
              set pair_id nobody
           ]
        ]
      ]
    ]
    if father != nobody [
      let father-agent turtle father
      if father-agent != nobody [
        ask father-agent [
          set chicks_alive chicks_alive - 1
          if chicks_alive <= 0[
              set clutch_state "fledged"
              set breeding? false
              set pair_id nobody
          ]
        ]
      ]
    ]
  ]
]

end

to storm 
  
  ; we are only simulating breeding season storms 
  if season = "non-breeding" [stop] 
  
  ; active storm continues:  
  if storm_active? [
    
    if storm_days_left = 0 [
      set storm_active? FALSE
      stop
    ]
    
    set storm_days_left storm_days_left - 1
    
    let storm_condition_loss 0
    let juvenile_loss 0  ; play around with this 
    let nest_risk 0
    
    ; daily consequences of a small storm
    if storm_severity = 1  [ ;"small"
      
      ; condition drops - reduced foraging capacity (for all independent birds)
      set storm_condition_loss small_cond_loss ; slider 
      set juvenile_loss (storm_condition_loss * juv_cond_loss)
      
      ask turtles with [life_stage = "adult" or life_stage = "immature" or life_stage = "juvenile"] [
        set condition condition - storm_condition_loss
        
        ; juveniles will loose more condition (less profficient at foraging) 
        ask turtles with [life_stage = "juvenile"] [
        set condition condition - juvenile_loss]
        
        if ((clutch_state = "incubating" or clutch_state = "with_chicks") and sex = "female") [  ; incubating females determine nest risk
          
          let hs [habitat_suitability] of patch-here
          let noise (random-float 0.2 - 0.1)   ;range: -0.1 to +0.1
          
          set nest_risk (1 - (hs / 2) + noise)  
          
          if nest_risk > nest_risk_thresh_small [
    
            ; add probability based on storm length and intensity
            if random-float 1 < nest_loss_small [    
              
              if clutch_state = "incubating"[
              set clutch_state "failed"
              set failed_nests failed_nests + 1
              set storm_egg_loss storm_egg_loss + clutch_size 
              ; alert partner 
              let partner turtle pair_id
              if partner != nobody [
                ask partner [
                  set clutch_state "failed"    
                ]
              ]
            ]
              
              if clutch_state = "with_chicks" [
                set clutch_state "finished"
                set storm_chick_loss storm_chick_loss + clutch_size 
                let partner turtle pair_id
                if partner != nobody [
                ask partner [
                  set clutch_state "finished"   
                  ]
                ]
              ]
            ]
          ]
        ]
      ]
    ]
    
    ; daily consequence of a large storm 
     if storm_severity = 2 [ ; "large" 
    ; condition drops - reduced foraging capacity 
    set storm_condition_loss large_cond_loss
    set juvenile_loss (storm_condition_loss * juv_cond_loss)
      
    ask turtles with [life_stage = "adult" or life_stage = "immature" or life_stage = "juvenile"] [      
        set condition condition - storm_condition_loss
        
        ; juveniles will loose more condition (less profficient at foraging) 
        ask turtles with [life_stage = "juvenile"] [
        set condition condition - juvenile_loss]
        
        if ((clutch_state = "incubating" or clutch_state = "with_chicks") and sex = "female") [  ; incubating females determine nest risk
          
          let hs [habitat_suitability] of patch-here
          let noise (random-float 0.2 - 0.1)   ;range: -0.1 to +0.1
          
          set nest_risk (1 - (hs / 2) + noise)  
          
         
          if nest_risk  > nest_risk_thresh_large [
            
            ; add probability based on storm length and intensity
            if random-float 1 < nest_loss_large [
              
              if clutch_state = "incubating" [
              set clutch_state "failed"     
             ; set failed_nests failed_nests + 1
              set storm_egg_loss storm_egg_loss + clutch_size 
              
              let partner turtle pair_id
              if partner != nobody [
                ask partner [
                  set clutch_state "failed"   
                  ]
                ]
              ]
              
              if clutch_state = "with_chicks"[
                set clutch_state "finished"
                set storm_chick_loss storm_chick_loss + clutch_size 
                let partner turtle pair_id
                if partner != nobody [
                ask partner [
                  set clutch_state "finished"   
                  ]
                ]
              ]
            ]
          ]
        ]
      ]
    ]
    
    ; daily consequence of an extreme storm 
    if storm_severity = 3 [ ; "extreme" 
      ; condition drops - reduced foraging capacity 
      set storm_condition_loss extreme_cond_loss
      set juvenile_loss (storm_condition_loss * juv_cond_loss)
      
      ask turtles with [life_stage = "adult" or life_stage = "immature" or life_stage = "juvenile"] [
         set condition condition - storm_condition_loss
        
        ; juveniles will loose more condition (less profficient at foraging) 
        ask turtles with [life_stage = "juvenile"] [
        set condition condition - juvenile_loss]
        
        if ((clutch_state = "incubating" or clutch_state = "with_chicks") and sex = "female") [  ; incubating females determine nest risk
          
          let hs [habitat_suitability] of patch-here
          let noise (random-float 0.2 - 0.1)   ;range: -0.1 to +0.1
          
          set nest_risk (1 - (hs / 2) + noise)  
          
          if nest_risk > nest_risk_thresh_extreme [
            
            ; add probability based on storm length and intensity
            if random-float 1 < nest_loss_extreme [
              
              if clutch_state = "incubating" [
              set clutch_state "failed"      
              set failed_nests failed_nests + 1
              set storm_egg_loss storm_egg_loss + clutch_size 
              
              let partner turtle pair_id
              if partner != nobody [
                ask partner [
                  set clutch_state "failed"
                ]
              ]
            ]
            
              if clutch_state = "with_chicks" [
                set clutch_state "finished"
                set storm_chick_loss storm_chick_loss + clutch_size 
                let partner turtle pair_id
                if partner != nobody [
                ask partner [
                  set clutch_state "finished"   
                  ]
                ]
              ]
            ]
          ]
        ]
      ]
    ]
  ]
  
    ; start a new storm ---------------------------------
  
  if season = "breeding" [
    if not storm_active? [
   ; let storm_event 1 - storm_prob
    if random-float 1 < storm_prob [ ; a new storm begins
      
      
      ; determine severity 
      let s random-float 1
      set storm_severity ifelse-value (s < 0.7) [1]
                         [ifelse-value (s < 0.90) [2] [3]]
      
      ; determine length 
      set storm_days_left random-poisson 1 ; think about the distribution for this - a 6 day storm is v long
      if storm_days_left < 1 [ set storm_days_left 1 ]
      
      set storm_active? true
      set storm_no storm_no + 1
      
      print (word "New " storm_severity " storm started, lasting " storm_days_left " days.")
    ]
  ]
]
end 

to predation 
  
  ; only occurs during breeding season
  if season != "breeding" [ stop ]

  ; predator arrives --------------------------------

  if not avian_predator_active? [
    if random-float 1 < avian_predator_prob [
      set avian_predator_active? true
      
      let p_gull 0.61
      let p_kahu 0.28
      let p_shorebird 0.11
      
      ; determine the type of avian predator 
      let r random-float 1;
      ifelse r < p_gull [
        set avian_species "gull"                        ; play around with this
        set gull_pres gull_pres + 1] [
        ifelse r < (p_gull + p_kahu) [
          set avian_species "kahu"
          set kahu_pres kahu_pres + 1] [
          set avian_species "shorebird"
          set shorebird_pres shorebird_pres + 1
  ]
]
 
      
      ; determine length of predator presence 
      let duration 1
      while [random-float 1 < 0.75] [ ; switch this to a slider to play around with it 
        set duration duration + 1]
      set avian_predator_days_left duration
    ]
  ]

  if not mam_predator_active? [
    if random-float 1 < mam_predator_prob [
      set mam_predator_active? true
      
      ; determine the type of mammalian predator 
      let r random-float 1; rat 0.9, mustellid 0.08, cat 0.02
      ifelse r < 0.9 [  
        set mam_species "rat"
        set rat_pres rat_pres + 1 ] [  
        ifelse r < 0.98 [    
          set mam_species "other" 
          set other_mam_pres other_mam_pres + 1 ] [    
          set mam_species "cat" 
          set cat_pres cat_pres + 1] 
      ]
      
      ; determine length of predator presence 
      let duration 1
      while [random-float 1 < 0.75] [ ; switch this to a slider to play around with it - could have different length for each predator type 
        set duration duration + 1]
      set mam_predator_days_left duration
    ]
  ]
    
  ; avian predators ----------------------------------
  
  if avian_predator_days_left > 0 [
    
    ; pick between eggs or chicks 
    
   let egg_attack false 
   let chick_attack false 
   
  ; others pick one or the other
  ifelse random-float 1 < 0.4
    [ set egg_attack true ]
    [ set chick_attack true ]


    ; egg predation ----------------
    if egg_attack [
    
    ; make a list of vulnerable nests 
    let vulnerable_nests turtles with [
      sex = "female" and 
      clutch_state = "incubating" and 
      clutch_size > 0 ]
    
    ; only continue if nests are present 
    if any? vulnerable_nests [
      
      ; sort by lowest habitat suitability 
      let sorted_nests sort-by [[a b] -> [habitat_suitability] of a < [habitat_suitability] of b] vulnerable_nests
      
      ; decide how many nests to attack 
      let nests_to_attack 0
      
        if avian_species = "gull" [
          set nests_to_attack 1
        ]
        if avian_species = "kahu" [
          set nests_to_attack 1
        ]
      if avian_species = "shorebird" [
        set nests_to_attack 1
      ]
        
        let targets turtle-set sublist sorted_nests 0 (min list nests_to_attack length sorted_nests)
        
          ask targets [
        
        ; set mean eggs taken based on predator
        let mean_take 0
        if avian_species = "gull" [ set mean_take gull_egg_take ]
        if avian_species = "kahu" [ set mean_take kahu_egg_take ]
        if avian_species = "shorebird" [ set mean_take shorebird_egg_take ]

  ; draw number of eggs taken (Poisson)
  let eggs_taken random-poisson mean_take
        
  ; ensure at least 1 egg is taken if attack happens
  if eggs_taken < 1 [ set eggs_taken 1 ]

  ; cannot take more eggs than exist
  set eggs_taken min list eggs_taken clutch_size
        
  ; update clutch
  set clutch_size clutch_size - eggs_taken

  ; update counters       
  set egg_loss_avian egg_loss_avian + eggs_taken
  set annual_egg_loss_avian annual_egg_loss_avian + eggs_taken

  


  ; check for clutch failure
  if clutch_size <= 0 [
    set clutch_size 0
    set clutch_state "finished"

    let partner turtle pair_id
    if partner != nobody [
      ask partner [
        set clutch_size 0
              set clutch_state "finished" ]
      ]
    ]
  ]
]
    ]


    
    ; chick predation ----------------
    
    if chick_attack [
    ; select vulnerable chicks
    let vulnerable_chicks turtles with [
      life_stage = "chick" ]
    
    if any? vulnerable_chicks [

  ; sort by lowest habitat suitability
  let sorted_chicks sort-by [[a b] -> [habitat_suitability] of a < [habitat_suitability] of b] vulnerable_chicks

  ; decide how many chicks to attack
  let chick_take_mean 0
    
        if avian_species = "gull" [ set chick_take_mean gull_chick_take ]
        if avian_species = "kahu" [ set chick_take_mean kahu_chick_take ]
        if avian_species = "shorebird" [ set chick_take_mean shorebird_chick_take ]

  ; draw number of eggs taken (Poisson)
    let chicks_to_attack random-poisson chick_take_mean

    let targets turtle-set sublist sorted_chicks 0 (min (list chicks_to_attack length sorted_chicks))

    ask targets [

      set chick_deaths chick_deaths + 1
      set chick_loss_avian chick_loss_avian + 1
      set annual_chick_loss_avian annual_chick_loss_avian + 1

      ; sibling attack (optional: keep stochastic)
 ;     if any? other turtles-here with [life_stage = "chick"] [
  ;      if random-float 1 < sibling_attack [

   ;       set chick_deaths chick_deaths + 1
   ;       set chick_loss_predators chick_loss_predators + 1
   ;       set chick_loss_avian chick_loss_avian + 1
   ;       set annual_chick_loss_avian annual_chick_loss_avian + 1

   ;       if turtle mother != nobody [
   ;         ask turtle mother [ set clutch_size clutch_size - 1 ]
   ;       ]
   ;       if turtle father != nobody [
   ;         ask turtle father [ set clutch_size clutch_size - 1 ]
   ;       ]

    ;      die
     ;   ]
     ; ]

      ; notify parents
      if turtle mother != nobody [
        ask turtle mother [
          set clutch_size clutch_size - 1
          if clutch_size <= 0 [ set clutch_state "finished" ]
        ]
      ]

      if turtle father != nobody [
        ask turtle father [
          set clutch_size clutch_size - 1
          if clutch_size <= 0 [ set clutch_state "finished" ]
        ]
      ]

      die
    ]
  ]
    ]



    ; reduce active days 
    set avian_predator_days_left avian_predator_days_left - 1

    if avian_predator_days_left <= 0 [
      set avian_predator_active? false
      set avian_species "none"
    ]
  ]

  ; mammalian predators -------------------------------------------------
  
    if mam_predator_active? and mam_predator_days_left > 0 [
    
     
   let egg_attack false 
   let chick_attack false 
   
   if mam_species = "cat" [
  ; cats can do both independently
  if random-float 1 < 0.63 [ set egg_attack true ]
  if random-float 1 < 0.37 [ set chick_attack true ]
      ; ensure at least one attack happens
  if (not egg_attack) and (not chick_attack) [
    ifelse random-float 1 < 0.63
      [ set egg_attack true ]
      [ set chick_attack true ]
  ]
]

if mam_species != "cat" [
  ; others pick one or the other
  ifelse random-float 1 < 0.63
    [ set egg_attack true ]
    [ set chick_attack true ]
]
  
    if egg_attack [
   ; make a list of vulnerable nests 
    let vulnerable_nests turtles with [
      sex = "female" and 
      clutch_state = "incubating" and 
      clutch_size > 0 ]
    
    ; only continue if nests are present 
    if any? vulnerable_nests [
      
      ; sort by lowest habitat suitability 
      let sorted_nests sort-by [[a b] -> [habitat_suitability] of a < [habitat_suitability] of b] vulnerable_nests
      
      ; decide how many nests to attack 
      let nests_to_attack 0
      
          if mam_species = "rat" [
            set nests_to_attack 1
          ]
          if mam_species = "other" [
            set nests_to_attack 1
          ]
          if mam_species = "cat" [
            set nests_to_attack 1
          ]
        

        
        let targets turtle-set sublist sorted_nests 0 (min list nests_to_attack length sorted_nests)
      
      ask targets [
      
      ; set mean eggs taken based on predator
      let mean_take 0
      if mam_species = "rat" [ set mean_take rat_egg_take ]
      if mam_species = "other" [ set mean_take other_egg_take ]
      if mam_species = "cat" [ set mean_take cat_egg_take ]

  ; draw number of eggs taken (Poisson)
  let eggs_taken random-poisson mean_take
        
  ; ensure at least 1 egg is taken if attack happens
  if eggs_taken < 1 [ set eggs_taken 1 ]

  ; cannot take more eggs than exist
  set eggs_taken min list eggs_taken clutch_size
        
  ; update clutch
  set clutch_size clutch_size - eggs_taken

  ; update counters
  set egg_loss_mammals egg_loss_mammals + eggs_taken
  set annual_egg_loss_mammals annual_egg_loss_mammals + eggs_taken


  ; check for clutch failure
  if clutch_size <= 0 [
    set clutch_size 0
    set clutch_state "finished"

    let partner turtle pair_id
    if partner != nobody [
      ask partner [
        set clutch_size 0
              set clutch_state "finished" ]
            ]
          ]
        ]
      ]
    ]


    ; chick predation ----------------
    
    if chick_attack [
    ; select vulnerable chicks
    let vulnerable_chicks turtles with [
      life_stage = "chick" ]
    
    if any? vulnerable_chicks [

  ; sort by lowest habitat suitability
  let sorted_chicks sort-by [[a b] -> [habitat_suitability] of a < [habitat_suitability] of b] vulnerable_chicks
        
          ; decide how many chicks to attack
        let chick_take_mean 0
    
        if mam_species = "rat" [ set chick_take_mean rat_chick_take ]
        if mam_species = "other" [ set chick_take_mean other_chick_take ]
        if mam_species = "cat" [ set chick_take_mean cat_chick_take ]

  ; draw number of eggs taken (Poisson)
    let chicks_to_attack random-poisson chick_take_mean

        
    let targets turtle-set sublist sorted_chicks 0 (min (list chicks_to_attack length sorted_chicks))

    ask targets [

      set chick_deaths chick_deaths + 1
      set chick_loss_mammals chick_loss_mammals + 1
      set annual_chick_loss_mammals annual_chick_loss_mammals + 1

      ; sibling attack (optional: keep stochastic)
 ;     if any? other turtles-here with [life_stage = "chick"] [
 ;       if random-float 1 < sibling_attack [

 ;         set chick_deaths chick_deaths + 1
  ;        set chick_loss_predators chick_loss_predators + 1
    ;     set chick_loss_mammals chick_loss_mammals + 1
    ;      set annual_chick_loss_mammals annual_chick_loss_mammals + 1

     ;     if turtle mother != nobody [
     ;       ask turtle mother [ set clutch_size clutch_size - 1 ]
     ;     ]
     ;     if turtle father != nobody [
     ;       ask turtle father [ set clutch_size clutch_size - 1 ]
     ;     ]

     ;     die
     ;   ]
     ; ]

      ; notify parents
      if turtle mother != nobody [
        ask turtle mother [
          set clutch_size clutch_size - 1
          if clutch_size <= 0 [ set clutch_state "finished" ]
        ]
      ]

      if turtle father != nobody [
        ask turtle father [
          set clutch_size clutch_size - 1
          if clutch_size <= 0 [ set clutch_state "finished" ]
        ]
      ]

      die
    ]
  ]
    ]

    ; reduce active days 
    set mam_predator_days_left mam_predator_days_left - 1

    if mam_predator_days_left <= 0 [
      set mam_predator_active? false
      set mam_species "none"
    ]
  ]

end 

; daily energetic costs --------------------------------------------------------
to energy_expenditure 
  
  if season = "non-breeding" [stop]
  
  ; general energy requirements ------------------------------------------------
  ask turtles with [life_stage != "chick"] [
    ; all birds will gain energy through foraging
    let gain max list 0 (random-normal mean_foraging_gain sd_foraging_gain)

    
    ; all birds will lose a certain amount from metabolic expenditure 
    let cost max list 0 (random-normal mean_metabolic_loss sd_metabolic_loss)
    
    ; net energy balance
    let net-energy gain - cost
    
    ; update condition
    set condition min list 1 (condition + net-energy) ; capped at 1
  ]
  
   ; incubating birds --------------------------------------------------------
  ask turtles with [clutch_state = "incubating"][
    set condition condition - incubation_cond_loss
    
    ; if condition falls below a point they will abandon the nest
    if condition < abandon_threshold [
      set clutch_state "failed" 
      set nest_reset 0
      set nest_reset_length max list 0 round random-normal 19 9
      
     ; set combined_egg_losses combined_egg_losses + clutch_size
        set abandoned_eggs abandoned_eggs + clutch_size ;
      
        if pair_id != nobody [
        let partner turtle pair_id
        ask partner [
          set clutch_state "failed"
        ]
      ]
    ]
  ]
  
  ; birds with chicks -------------------------------------------------------
  ask turtles with [clutch_state = "with_chicks"][
    set condition condition - with_chick_cond_loss    
    
    if condition < abandon_threshold [
      set clutch_state "finished"
      
    ]
  ]
  
  ; solo parents 
  ask turtles with [clutch_state = "with_chicks_solo"][
    set condition condition - (with_chick_cond_loss * 2)
  
  ; if condition drops below threshold the bird will abandon the chicks 
    if condition < abandon_threshold [
    set clutch_state "finished"
    ]
  ]
    
  
  ; bird death -------------------------------------------------------------- 
    ask turtles with [condition <= 0] [
    if life_stage = "adult" [
    set adult_deaths adult_deaths + 1    ; need to consider the maths census deaths/total adults per year
    die
    ]
    
    if life_stage = "immature" [
      set immature_deaths immature_deaths + 1
      die
    ]
    
    if life_stage = "juvenile" [
      set juvenile_deaths juvenile_deaths + 1
      die
    ]
  ]
  
end 




to off_season 
  if season = "breeding" [stop]
  
  ; during overwintering there is a probability of mortality 
  
  ask turtles with [life_stage = "adult"][
  if random-float 1 <= winter_adult_mort [
      set winter_adult_deaths winter_adult_deaths + 1
      die ]
  ]
  ; older birds have an additional "sensecene" mortality risk
  ask turtles with [life_stage = "adult" and age_years > 16][
    if random-float 1 <= winter_elder_mort[
      set winter_adult_deaths winter_adult_deaths + 1
      die]
  ]
  
  ask turtles with [life_stage = "immature"][
    if random-float 1 <= winter_imm_mort [
      set winter_immature_deaths winter_immature_deaths + 1
      die ]
  ]
  
  ask turtles with [life_stage = "juvenile"][
       if random-float 1 <= winter_juv_mort [
       set winter_juvenile_deaths winter_juvenile_deaths + 1
       die ]
  ]
  
  
end 



; resetting for a new day -------------------------------------------------------------
to new_day

  ; end of the year reset -------------------------------------------------------------
  if day = 365 [

    ; reset breeding variables for all birds
    ask turtles [
      set clutch_state "none"
      set breeding? false
      set courting_time 0
      set courting_length 0
      set incubation_time 0
      set clutch_no 0
      set chicks_alive 0
      set final_clutch? false
      
      ask turtles with [life_stage = "adult"][
        set condition min list 1 (condition + (random-normal mean_breeding_prep sd_breeding_prep))] ; assumes they prep for the upcoming season 
  ] ]
  
  ; update day 
ifelse day = 365 [
  set year year + 1
  set day 0
] [
  set day day + 1
]


  ; update season ---------------------------------------
  ifelse day <= 120[
    set season "breeding"]
  [
    set season "non-breeding"]

  ; end of breeding season (day 91)
  if day = 121 [

    ; birds with no active nests
    ask turtles with [clutch_state = "none" or clutch_state = "failed" or clutch_state = "finished"] [
      set breeding? false
      set incubation_time 0
      set clutch_no 0
      set clutch_state "none"
      set chicks_alive 0
    ]

    ; birds still nesting cannot start new clutches
    ask turtles with
      [clutch_state = "incubating"
       or clutch_state = "with_chicks"] [
      set final_clutch? true
    ]
  ]

  if day = 122 and year > 0[
  
  ;; yearly reporting
    yearly_report
    reset_annual_counters
  
  ]
  ; age update ----------------------------------------

  ask turtles [
    
    set age_day age_day + 1
    if age_day >= 365 [
      set age_day 0
      set age_years age_years + 1]
    
    ; update life stages
    ; juveniles 
    if age_years = 1 and age_day = 0 [
      set life_stage "immature" 
      set juvenile_success juvenile_success + 1
    ]

    ; immatures
    if age_years = 1 and age_day = 320 [
      set life_stage "adult"
      set immature_success immature_success + 1     
    ]



  ]


  ; demographic reporting -------------------------------

  set total_birds count turtles

end


to update_outputs
  
 ; plots 
  ; sex --------------------------------------
  set-current-plot "sex_ratio"

  set-current-plot-pen "males"
  plot count turtles with [sex = "male"]

  set-current-plot-pen "females"
  plot count turtles with [sex = "female"]

  ; breeding ---------------------------------
  set-current-plot "breeding_population"

  set-current-plot-pen "all_adults"
  plot count turtles with [life_stage = "adult"]

  set-current-plot-pen "breeding_adults"
  plot count turtles with [breeding?]

  ; population structure ---------------------
  set-current-plot "population_structure"

  set-current-plot-pen "adult"
  plot count turtles with [life_stage = "adult"]

  set-current-plot-pen "immature"
  plot count turtles with [life_stage = "immature"]

  set-current-plot-pen "juvenile"
  plot count turtles with [life_stage = "juvenile"]

  set-current-plot-pen "chick"
  plot count turtles with [life_stage = "chick"]
  
  ; age structure ---------------------------
;  set-current-plot "age_structure"
  
;  clear-plot
  
;  histogram [age_years] of turtles

  
end 

to yearly_report

  let hatching_rate 0
  let fledging_rate 0
  let productivity 0
  

  if fertile_eggs > 0 [
    set hatching_rate hatched / fertile_eggs
  ]

  if hatched > 0 [
    set fledging_rate fledged / hatched
  ]

  if total_eggs > 0 [
    set productivity fledged / total_eggs
  ]
  
  let total_adult_deaths (adult_deaths + winter_adult_deaths)
  
  if annual_adult_start_year > 0 [
  set annual_adult_survival (annual_adult_start_year - total_adult_deaths) / annual_adult_start_year
  ]

  print (word "Year: " year)
  print (word "Total eggs: " total_eggs)
  print (word "Hatching rate: " hatching_rate)
  print (word "Fledging rate: " fledging_rate)
  print (word "Overall productivity: " productivity)
  print (word "Adult survival: " annual_adult_survival)
  print "---------------------------"

end

to reset_annual_counters ; write these to a csv
  
   set annual_adult_start_year count turtles with [life_stage = "adult"]
   set adult_deaths 0 
   set winter_adult_deaths 0

 ; set total_eggs 0
